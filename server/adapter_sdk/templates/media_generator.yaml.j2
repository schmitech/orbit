# Dedicated {{ media_type }} generation adapter — converts text prompts to {{ media_type }} via AI.
# Handled by the {{ media_type }} generation step; LLMInferenceStep is skipped for this adapter type.
adapters:
  - name: "{{ name }}"
    enabled: {{ enabled | lower }}
    type: "{{ type }}"
    datasource: "{{ datasource }}"
    adapter: "{{ adapter }}"
    implementation: "{{ implementation }}"
{%- if media_provider %}
    {{ provider_field }}: "{{ media_provider }}"   # Optional adapter override; omit to use the global default
{%- endif %}
{%- if rewrite_provider %}
    rewrite_provider: "{{ rewrite_provider }}"   # Text LLM used to enrich the prompt
{%- endif %}
{%- if rewrite_model %}
    rewrite_model: "{{ rewrite_model }}"
{%- endif %}

    capabilities:
      expose_as_skill: true
      skill_name: "{{ skill_name }}"
      skill_description: "{{ skill_description }}"
{%- if routing_examples %}
      # Phrases that boost the skill-intent embedding pre-filter (auto-routing).
      routing_examples:
{%- for phrase in routing_examples %}
        - "{{ phrase }}"
{%- endfor %}
{%- endif %}
      retrieval_behavior: "none"
      formatting_style: "clean"
      supports_threading: false
      supports_file_ids: false
      supports_session_tracking: true
      requires_api_key_validation: false
      optional_parameters:
{%- for param in optional_parameters %}
        - "{{ param }}"
{%- endfor %}
{%- if has_config %}

    config:
      storage_backend: "{{ storage_backend }}"
      storage_root: "{{ storage_root }}"
{%- endif %}
