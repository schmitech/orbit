export NODE_OPTIONS="--no-deprecation"

# Authentication provider: "auth0" (default) or "entra"
# When set here, takes precedence over `auth.provider` in orbitchat.yaml.
VITE_AUTH_PROVIDER=

# ---- Auth0 settings (when VITE_AUTH_PROVIDER=auth0 or unset) ----
# Auth0 tenant domain (e.g. myapp.auth0.com)
VITE_AUTH_DOMAIN=
# Auth0 application client ID
VITE_AUTH_CLIENT_ID=
# Auth0 API audience identifier (optional)
VITE_AUTH_AUDIENCE=

# ---- Entra ID / Azure AD settings (when VITE_AUTH_PROVIDER=entra) ----
# Azure AD application (client) ID — replaces VITE_AUTH_CLIENT_ID above
# VITE_AUTH_CLIENT_ID=
# Azure AD tenant ID (e.g. xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx or "common")
VITE_AUTH_TENANT_ID=
# Token scopes, space-separated or JSON array (optional; defaults to "openid profile email")
VITE_AUTH_SCOPES=

# Mapping of Adapter IDs (from orbitchat.yaml `id` field) to their secret API keys.
# Metadata like apiUrl, description, and notes should stay in orbitchat.yaml.
# External startup JS tags (analytics/ads/etc.) are configured in orbitchat.yaml `startupScripts`.
VITE_ADAPTER_KEYS='{
  "simple-chat": "default-key",
  "chat-with-files": "multimodal",
  "intent-sql-sqlite-hr": "hr",
  "intent-duckdb-analytics": "analytical",
  "intent-duckdb-ev-population": "ev",
  "intent-sql-postgres": "postgres",
  "composite-multi-source-explorer": "composite",
  "intent-elasticsearch-app-logs": "elasticsearch",
  "intent-http-jsonplaceholder": "rest",
  "intent-http-paris-opendata": "paris",
  "intent-firecrawl-webscrape": "web",
  "intent-mongodb-mflix": "mflix",
  "intent-graphql-spacex": "spacex",
  "intent-agent-example": "agent"
}'
