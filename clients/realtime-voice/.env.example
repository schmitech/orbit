# ORBIT Realtime Voice Bridge — copy to .env.local

# WebSocket base URL (no /ws/voice path)
VITE_ORBIT_SERVER_URL=ws://localhost:3000

# REST base if it differs from the WS host (optional)
# VITE_ORBIT_API_URL=http://localhost:3000

# Adapter to connect to — any type: openai_realtime / openai_realtime_translation /
# gemini_live adapter from config/adapters/audio.yaml, e.g.:
#   open-ai-real-time-voice-chat, gemini-live-voice-chat
VITE_ADAPTER_NAME=open-ai-real-time-voice-chat

# Optional: if set, validates via /admin/api-keys/... and may override adapter from key
# VITE_API_KEY=

VITE_APP_TITLE=ORBIT Realtime Voice Bridge

# true = show server URL / adapter / API key fields in the UI
VITE_DISPLAY_SETTINGS=false
