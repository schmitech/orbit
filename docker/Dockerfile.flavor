FROM python:3.12-slim

WORKDIR /orbit

ARG CUDA_VER=cu121
ARG UID=1001
ARG GID=0
# Image default profile (a user can still pick a different one at runtime via
# -e ORBIT_PROFILE=..., as long as INCLUDE_OLLAMA matches what that profile needs).
ARG ORBIT_FLAVOR=openai
# Whether to bundle a local Ollama runtime. Required for the ollama flavor
# (inference + vision + embeddings all run locally); not needed for openai/gemini.
ARG INCLUDE_OLLAMA=false
# Node.js version for the bundled orbitchat UI.
ARG NODE_MAJOR=20

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    git \
    gcc \
    g++ \
    make \
    libssl-dev \
    libffi-dev \
    libpq-dev \
    jq \
    zstd \
    libopenblas-dev \
    numactl \
    ca-certificates \
    gnupg \
    tini \
    && curl -fsSL https://deb.nodesource.com/setup_${NODE_MAJOR}.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# Bundled Ollama runtime — only for images that declare INCLUDE_OLLAMA=true.
RUN if [ "$INCLUDE_OLLAMA" = "true" ]; then \
        curl -fsSL https://ollama.com/install.sh | sh; \
    fi

ENV OMP_NUM_THREADS=4 \
    MKL_NUM_THREADS=4 \
    OPENBLAS_NUM_THREADS=4 \
    VECLIB_MAXIMUM_THREADS=4 \
    NUMEXPR_NUM_THREADS=4 \
    MALLOC_TRIM_THRESHOLD_=100000 \
    TOKENIZERS_PARALLELISM=false \
    PYTHONUNBUFFERED=1 \
    HF_HOME=/orbit/data/cache/hf \
    SCARF_NO_ANALYTICS=true \
    DO_NOT_TRACK=true \
    ANONYMIZED_TELEMETRY=false \
    HF_HUB_DISABLE_TELEMETRY=1 \
    CUDA_VER=${CUDA_VER}

# ═══════════════════════════════════════════════════════════════════════════
# ORBIT server
# ═══════════════════════════════════════════════════════════════════════════
COPY install/dependencies.toml /orbit/install/
COPY install/generate_requirements.py /orbit/install/
COPY install/setup.sh /orbit/install/
RUN chmod +x /orbit/install/setup.sh

RUN pip install --no-cache-dir --upgrade pip setuptools wheel && \
    pip install --no-cache-dir uv tomli && \
    cd /orbit/install && \
    python3 generate_requirements.py all --output /tmp/requirements.txt && \
    grep -Ev '^(torch|torchvision)([<=>[:space:]]|$)' /tmp/requirements.txt > /tmp/requirements-no-torch.txt && \
    uv pip install --system --no-cache-dir -r /tmp/requirements-no-torch.txt && \
    uv pip install --system --no-cache-dir --index-url "https://download.pytorch.org/whl/${CUDA_VER}" \
        "torch>=2.2.2,<3.0.0" \
        "torchvision>=0.17.0,<1" && \
    rm /tmp/requirements-no-torch.txt /tmp/requirements.txt

COPY server/ /orbit/server/
COPY bin/ /orbit/bin/
COPY LICENSE* /orbit/

# Canonical default-config tree is the single source of truth for generated
# runtime config; see docker/runtime_profiles.py.
COPY install/default-config/ /orbit/config/

# server/vector_stores/base/store_manager.py's StoreManager() defaults to
# loading "config/stores.yaml" relative to CWD (/orbit) directly off disk —
# it does not go through the --config/config-runtime resolution path, so
# docker/runtime_profiles.py patching config-runtime/stores.yaml at container
# start never reaches it. Bake the same writable, non-root-safe path here
# instead; it is not profile-dependent, so a build-time fix is correct.
RUN python3 -c "\
import yaml; \
p = '/orbit/config/stores.yaml'; \
data = yaml.safe_load(open(p)); \
data['vector_stores']['chroma']['connection_params']['persist_directory'] = '/orbit/data/chroma_db'; \
yaml.safe_dump(data, open(p, 'w'), sort_keys=False, default_flow_style=False, allow_unicode=True)"
COPY install/orbit.db.default /orbit/orbit.db.default
COPY env.example /orbit/env.example

RUN chmod +x /orbit/bin/orbit.py /orbit/bin/orbit.sh

# ═══════════════════════════════════════════════════════════════════════════
# orbitchat UI (bundled — dist/ is prebuilt and checked into the repo)
# ═══════════════════════════════════════════════════════════════════════════
COPY clients/orbitchat/package.json clients/orbitchat/package-lock.json /orbit/orbitchat/
RUN cd /orbit/orbitchat && npm ci --omit=dev --ignore-scripts
COPY clients/orbitchat/dist/ /orbit/orbitchat/dist/
COPY clients/orbitchat/bin/ /orbit/orbitchat/bin/
COPY clients/orbitchat/orbitchat.yaml.example /orbit/orbitchat/orbitchat.yaml.example

# ═══════════════════════════════════════════════════════════════════════════
# Runtime profile resolver
# ═══════════════════════════════════════════════════════════════════════════
COPY docker/runtime_profiles.py /orbit/docker/runtime_profiles.py
COPY docker/entrypoint-flavor.sh /orbit/entrypoint-flavor.sh
RUN chmod +x /orbit/entrypoint-flavor.sh

# Image capability marker consumed by entrypoint-flavor.sh: rejects a runtime
# ORBIT_PROFILE the image wasn't built to support (e.g. ollama on a
# no-Ollama image) before anything starts.
RUN printf 'IMAGE_FLAVOR=%s\nIMAGE_HAS_OLLAMA=%s\n' "$ORBIT_FLAVOR" "$INCLUDE_OLLAMA" > /orbit/.orbit-flavor

RUN mkdir -p /orbit/logs /orbit/data /orbit/models /orbit/config-runtime

ENV PYTHONPATH=/orbit:/orbit/server
ENV PATH="/orbit/bin:${PATH}"
ENV ENVIRONMENT=production
ENV ORBIT_DEFAULT_ADMIN_PASSWORD=admin123
ENV ORBIT_PROFILE=${ORBIT_FLAVOR}
# Non-root: keep Ollama's model store under a directory the "orbit" user
# owns rather than the default /root/.ollama. Mount a volume at
# /orbit/models to persist downloaded models across restarts.
ENV OLLAMA_MODELS=/orbit/models

EXPOSE 3000 5173

HEALTHCHECK --interval=30s --timeout=10s --start-period=90s --retries=3 \
  CMD curl -sf http://localhost:3000/health | jq -e '.status == "healthy"' > /dev/null || exit 1

RUN if ! getent group "${GID}" >/dev/null; then groupadd -r -g "${GID}" orbit; fi && \
    useradd -r -u "${UID}" -g "${GID}" -m -d /home/orbit orbit && \
    chown -R orbit:"${GID}" /orbit/logs /orbit/data /orbit/models /orbit/config-runtime /orbit/orbitchat /home/orbit && \
    chown orbit:"${GID}" /orbit/orbit.db.default && \
    chmod 640 /orbit/orbit.db.default

USER orbit

ENTRYPOINT ["/usr/bin/tini", "--", "/orbit/entrypoint-flavor.sh"]
