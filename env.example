API_SERVER_URL=http://localhost:3000
API_ADMIN_TOKEN=admin token
ORBIT_DEFAULT_ADMIN_PASSWORD=admin123

# ==========================================
# External Identity Providers (optional)
# ==========================================
# Only needed if you enable auth.providers in config/config.yaml (bearer-token
# validation and/or admin-panel SSO for Microsoft Entra ID and Auth0).
# Leave unset to use built-in username/password auth only.
#
# Microsoft Entra ID (Azure AD)
# ORBIT_AUTH_ENTRA_TENANT_ID=your-directory-tenant-id
# ORBIT_AUTH_ENTRA_CLIENT_ID=your-application-client-id     # expected token audience
# ORBIT_AUTH_ENTRA_CLIENT_SECRET=                           # optional; only for admin-panel SSO confidential clients
#
# Auth0
# ORBIT_AUTH_AUTH0_DOMAIN=your-tenant.us.auth0.com
# ORBIT_AUTH_AUTH0_AUDIENCE=https://your-api-identifier     # API identifier = expected access-token audience
# ORBIT_AUTH_AUTH0_CLIENT_ID=your-application-client-id     # required for admin-panel SSO (id_token audience)
# ORBIT_AUTH_AUTH0_CLIENT_SECRET=                           # optional; only for admin-panel SSO confidential clients
#
# Admin-panel SSO redirect base (optional): set when behind a reverse proxy so the
# registered redirect URI {base}/admin/auth/{entra|auth0}/callback matches.
# ORBIT_ADMIN_BASE_URL=https://orbit.example.com

# ==========================================
# Secrets Management (optional)
# ==========================================
# Only needed if you set secrets_management.provider in config/config.yaml to
# "aws", "azure", or "gcp". The default "env" provider resolves ${VAR}
# placeholders from this .env file / the process environment only, and needs
# none of these. Requires the 'secrets-management' dependency profile for the
# cloud providers:
#   ./install/setup.sh --profile secrets-management
#
# ORBIT_SECRETS_PROVIDER=env
#
# --- AWS Secrets Manager --- (provider: aws)
# Uses the boto3 default credential chain (env / instance role / SSO); reuses
# AWS_REGION defined below.
# ORBIT_SECRETS_AWS_ENDPOINT_URL=           # optional, e.g. LocalStack for testing
#
# --- Azure Key Vault --- (provider: azure)
# Uses DefaultAzureCredential (managed identity / Entra / az login).
# AZURE_KEY_VAULT_URL=https://your-vault.vault.azure.net/
#
# --- GCP Secret Manager --- (provider: gcp)
# Uses Application Default Credentials; reuses GOOGLE_CLOUD_PROJECT defined below.

# ==========================================
# Cloud File Storage (optional)
# ==========================================
# Only needed if you set files.storage_backend in config/config.yaml to
# "s3", "minio", "azure", or "gcs". The default "filesystem" backend needs none of these.
# Requires the 'cloud-services' dependency profile:
#   ./install/setup.sh --profile cloud-services
#
# --- AWS S3 / S3-compatible (MinIO) --- (storage_backend: s3 or minio)
# The bucket must already exist.
# ORBIT_S3_BUCKET=your-orbit-uploads-bucket
# ORBIT_S3_PREFIX=                          # optional key prefix within the bucket
# AWS_REGION=us-east-1
# ORBIT_S3_ENDPOINT_URL=http://localhost:9000   # set for MinIO / S3-compatible stores
# Credentials: omit to use the boto3 default chain (env / instance role / SSO).
# AWS_SECRET_ACCESS_KEY is already defined below (Bedrock); set AWS_ACCESS_KEY_ID too if using explicit keys.
# AWS_ACCESS_KEY_ID=your-key
#
# --- Azure Blob --- (storage_backend: azure)
# The container must already exist.
# ORBIT_AZURE_CONTAINER=your-orbit-uploads-container
# ORBIT_AZURE_PREFIX=                       # optional blob-name prefix
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
# Or identity-based auth (managed identity / Entra) instead of a connection string:
# AZURE_STORAGE_ACCOUNT_URL=https://youraccount.blob.core.windows.net
# AZURE_STORAGE_ACCOUNT_KEY=                # omit to use DefaultAzureCredential
#
# --- Google Cloud Storage --- (storage_backend: gcs)
# The bucket must already exist.
# ORBIT_GCS_BUCKET=your-orbit-uploads-bucket
# ORBIT_GCS_PREFIX=                         # optional object-name prefix
# GOOGLE_CLOUD_PROJECT=your-gcp-project     # optional; inferred from credentials if omitted
# Credentials: omit to use Application Default Credentials (Workload Identity on GCP, or gcloud locally).
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json   # explicit service-account key file

# ==========================================
# File Encryption (optional)
# ==========================================
# Only needed if you set files.encryption.enabled: true in config/config.yaml.
# Used for adapters that declare capabilities.requires_encryption: true, to
# encrypt file bytes at rest (AES-256-GCM) regardless of which storage backend is used.
# Generate with:
#   python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# ORBIT_FILE_ENCRYPTION_KEY=

# Application environment
# Set to "production" to disable autogenerated FastAPI docs at /docs, /redoc, and /openapi.json
ENVIRONMENT=development

# ==========================================
# Backend Database Configuration
# ==========================================
# Orbit supports three backend databases:
# 1. SQLite (default) - No installation required, uses local file
# 2. MongoDB - Requires MongoDB server
# 3. PostgreSQL - Requires PostgreSQL server
#
# To use SQLite (recommended for development/testing):
#   - Set backend.type to "sqlite" in config/config.yaml
#   - No environment variables needed
#   - Database file will be created at the path specified in config.yaml
#
# To use MongoDB:
#   - Set backend.type to "mongodb" in config/config.yaml
#   - Configure MongoDB environment variables below
#
# To use PostgreSQL:
#   - Set backend.type to "postgres" in config/config.yaml
#   - Configure the INTERNAL_SERVICES_POSTGRES_* environment variables below

# Elasticsearch Logging Service
INTERNAL_SERVICES_ELASTICSEARCH_NODE=https://localhost:9000
INTERNAL_SERVICES_ELASTICSEARCH_USERNAME=elastic-user
INTERNAL_SERVICES_ELASTICSEARCH_PASSWORD=elastic-password

# MongoDB Backend Configuration (only needed if using MongoDB backend)
INTERNAL_SERVICES_MONGODB_HOST=localhost
INTERNAL_SERVICES_MONGODB_PORT=27017
INTERNAL_SERVICES_MONGODB_DB=orbit
INTERNAL_SERVICES_MONGODB_USERNAME=
INTERNAL_SERVICES_MONGODB_PASSWORD=

# PostgreSQL Backend Configuration (only needed if using Postgres backend, i.e.
# internal_services.backend.type: "postgres" in config/config.yaml).
# This is distinct from DATASOURCE_POSTGRES_* below, which configures the
# RAG/retrieval Postgres datasource, not the internal services backend.
INTERNAL_SERVICES_POSTGRES_HOST=localhost
INTERNAL_SERVICES_POSTGRES_PORT=5432
INTERNAL_SERVICES_POSTGRES_DB=orbit
INTERNAL_SERVICES_POSTGRES_USERNAME=postgres
INTERNAL_SERVICES_POSTGRES_PASSWORD=
INTERNAL_SERVICES_POSTGRES_SSLMODE=prefer

INTERNAL_SERVICES_REDIS_HOST=localhost
INTERNAL_SERVICES_REDIS_PORT=11146
INTERNAL_SERVICES_REDIS_USERNAME=default
INTERNAL_SERVICES_REDIS_PASSWORD=redis-password

# Postgres Credentials (RAG datasource - see INTERNAL_SERVICES_POSTGRES_* above for the backend DB)
DATASOURCE_POSTGRES_USERNAME=postgres
DATASOURCE_POSTGRES_PASSWORD=postgres-passwrod
DATASOURCE_POSTGRES_HOST=localhost
DATASOURCE_POSTGRES_PORT=5432
DATASOURCE_POSTGRES_DATABASE=orbit
DATASOURCE_POSTGRES_SSL_MODE=require

# MongoDB Datasource Configuration
# Option 1: MongoDB Atlas (recommended for sample_mflix)
DATASOURCE_MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/sample_mflix?retryWrites=true&w=majority
DATASOURCE_MONGODB_DATABASE=sample_mflix

# Option 2: Local/Self-hosted MongoDB (alternative)
DATASOURCE_MONGODB_HOST=localhost
DATASOURCE_MONGODB_PORT=27017
DATASOURCE_MONGODB_USERNAME=mongo-user
DATASOURCE_MONGODB_PASSWORD=mongo-password
DATASOURCE_MONGODB_AUTH_SOURCE=admin
DATASOURCE_MONGODB_TLS=false

# Note: If MONGODB_URI is provided, it takes precedence over individual host/port settings

# Redis Credentials
DATASOURCE_REDIS_HOST=localhost
DATASOURCE_REDIS_PORT=6379
DATASOURCE_REDIS_PASSWORD=redis-password

# Redis Credentials
DATASOURCE_REDIS_PASSWORD=redis-password

# Elasticsearch Credentials
DATASOURCE_ELASTICSEARCH_NODE=elastic-endpoint
DATASOURCE_ELASTICSEARCH_USERNAME=elastic
DATASOURCE_ELASTICSEARCH_PASSWORD=your_elasticsearch_password

# Qdrant Configuration
# For Qdrant Cloud: set URL and API_KEY (leave HOST/PORT empty)
DATASOURCE_QDRANT_URL=https://your-cluster-id.region.cloud.qdrant.io:6333
DATASOURCE_QDRANT_API_KEY=your-qdrant-api-key

# For self-hosted Qdrant: set HOST and PORT (leave URL empty)
# DATASOURCE_QDRANT_URL=
DATASOURCE_QDRANT_HOST=localhost
DATASOURCE_QDRANT_PORT=6333

# Pinecone Configuration
DATASOURCE_PINECONE_API_KEY=your-key
DATASOURCE_PINECONE_HOST=https://domain.pinecone.io

# Supabase Configuration
DATASOURCE_SUPABASE_HOST=your-supabase-host
DATASOURCE_SUPABASE_PORT=5432
DATASOURCE_SUPABASE_DATABASE=your-supabase-database
DATASOURCE_SUPABASE_USERNAME=your-supabase-username
DATASOURCE_SUPABASE_PASSWORD=your-supabase-password

# Oracle Configuration
DATASOURCE_ORACLE_HOST=your-oracle-host
DATASOURCE_ORACLE_PORT=1521
DATASOURCE_ORACLE_SERVICE=your-oracle-service
DATASOURCE_ORACLE_USERNAME=your-oracle-username
DATASOURCE_ORACLE_PASSWORD=your-oracle-password

# MySQL Configuration
DATASOURCE_MYSQL_HOST=your-mysql-host
DATASOURCE_MYSQL_PORT=3306
DATASOURCE_MYSQL_DATABASE=your-mysql-database
DATASOURCE_MYSQL_USERNAME=your-mysql-username
DATASOURCE_MYSQL_PASSWORD=your-mysql-password

# MariaDB Configuration
DATASOURCE_MARIADB_HOST=your-mariadb-host
DATASOURCE_MARIADB_PORT=3306
DATASOURCE_MARIADB_DATABASE=your-mariadb-database
DATASOURCE_MARIADB_USERNAME=your-mariadb-username
DATASOURCE_MARIADB_PASSWORD=your-mariadb-password

# SQL Server Configuration
DATASOURCE_SQLSERVER_HOST=your-sqlserver-host
DATASOURCE_SQLSERVER_PORT=1433
DATASOURCE_SQLSERVER_DATABASE=your-sqlserver-database
DATASOURCE_SQLSERVER_USERNAME=your-sqlserver-username
DATASOURCE_SQLSERVER_PASSWORD=your-sqlserver-password

# Cassandra Configuration
DATASOURCE_CASSANDRA_HOSTS=your-cassandra-hosts
DATASOURCE_CASSANDRA_PORT=9042
DATASOURCE_CASSANDRA_KEYSPACE=your-cassandra-keyspace
DATASOURCE_CASSANDRA_USERNAME=your-cassandra-username
DATASOURCE_CASSANDRA_PASSWORD=your-cassandra-password

# Athena Configuration
# Athena uses AWS IAM credentials and requires an S3 staging bucket path.
# Recommended: set dedicated Athena credentials below.
# If these are left empty, pyathena will use the AWS default credential chain
# (e.g., AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY, profile, role, or instance creds).
DATASOURCE_ATHENA_ACCESS_KEY_ID=
DATASOURCE_ATHENA_SECRET_ACCESS_KEY=
DATASOURCE_ATHENA_SESSION_TOKEN=
DATASOURCE_ATHENA_REGION=us-east-1
DATASOURCE_ATHENA_S3_STAGING_DIR=s3://your-athena-query-results-bucket/prefix/
DATASOURCE_ATHENA_SCHEMA=default
DATASOURCE_ATHENA_CATALOG=AwsDataCatalog
DATASOURCE_ATHENA_WORKGROUP=primary

FIRECRAWL_API_KEY=your-key
OLLAMA_CLOUD_API_KEY=your-key

AWS_BEDROCK_ACCESS_KEY=your-key
AWS_SECRET_ACCESS_KEY=your-key
AZURE_ACCESS_KEY=your-key
OPENAI_API_KEY=your-key
GOOGLE_API_KEY=your-key
